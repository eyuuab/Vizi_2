// ============================================================
// SlideForge AI — Prisma Schema
// Section 4: Data Model & Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----

enum UserPlan {
  FREE
  PRO
  TEAM
}

enum AssetType {
  IMAGE
  VIDEO
  ICON
  CHART_DATA
  DOCUMENT
}

// ---- Section 4.2.1: User Metadata (Clerk-synced) ----
// Store app-specific user data, Clerk handles auth

model UserMetadata {
  clerkUserId   String   @id // Clerk's user ID
  plan          UserPlan @default(FREE)
  aiCreditsUsed Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  presentations Presentation[]
  themes        Theme[]
  assets        Asset[]

  @@map("user_metadata")
}

// ---- Section 4.2.2: Presentation Model ----

model Presentation {
  id          String   @id @default(cuid())
  title       String
  description String?
  clerkUserId String
  themeId     String
  isPublic    Boolean  @default(false)
  shareSlug   String?  @unique
  thumbnail   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     UserMetadata @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: Cascade)
  theme    Theme        @relation(fields: [themeId], references: [id])
  sections Section[]
  assets   Asset[]

  @@index([clerkUserId])
  @@index([shareSlug])
  @@map("presentations")
}

// ---- Section 4.2.3: Section Model ----

model Section {
  id             String  @id @default(cuid())
  presentationId String
  layoutId       String
  order          Int
  content        Json
  styleOverrides Json?
  transitions    Json?
  notes          String?
  isHidden       Boolean @default(false)

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([presentationId, order])
  @@map("sections")
}

// ---- Section 4.2.4: Theme Model ----

model Theme {
  id          String  @id @default(cuid())
  name        String
  clerkUserId String?
  isPreset    Boolean @default(false)
  tokens      Json
  preview     String?

  user          UserMetadata?  @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: SetNull)
  presentations Presentation[]

  @@index([clerkUserId])
  @@index([isPreset])
  @@map("themes")
}

// ---- Section 4.2.5: Asset Model ----

model Asset {
  id             String    @id @default(cuid())
  clerkUserId    String
  presentationId String?
  type           AssetType
  url            String
  filename       String
  mimeType       String
  sizeBytes      Int
  metadata       Json?
  createdAt      DateTime  @default(now())

  user         UserMetadata  @relation(fields: [clerkUserId], references: [clerkUserId], onDelete: Cascade)
  presentation Presentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)

  @@index([clerkUserId])
  @@index([presentationId])
  @@map("assets")
}

// NextAuth models removed - Clerk handles authentication
