// ============================================================
// SlideForge AI — Prisma Schema
// Section 4: Data Model & Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----

enum UserPlan {
  FREE
  PRO
  TEAM
}

enum AssetType {
  IMAGE
  VIDEO
  ICON
  CHART_DATA
  DOCUMENT
}

// ---- Section 4.2.1: User Model ----

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  plan           UserPlan  @default(FREE)
  aiCreditsUsed  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  presentations Presentation[]
  themes        Theme[]
  assets        Asset[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

// ---- Section 4.2.2: Presentation Model ----

model Presentation {
  id          String   @id @default(cuid())
  title       String
  description String?
  userId      String
  themeId     String
  isPublic    Boolean  @default(false)
  shareSlug   String?  @unique
  thumbnail   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme    Theme     @relation(fields: [themeId], references: [id])
  sections Section[]
  assets   Asset[]

  @@index([userId])
  @@index([shareSlug])
  @@map("presentations")
}

// ---- Section 4.2.3: Section Model ----

model Section {
  id             String  @id @default(cuid())
  presentationId String
  layoutId       String
  order          Int
  content        Json
  styleOverrides Json?
  transitions    Json?
  notes          String?
  isHidden       Boolean @default(false)

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([presentationId, order])
  @@map("sections")
}

// ---- Section 4.2.4: Theme Model ----

model Theme {
  id       String  @id @default(cuid())
  name     String
  userId   String?
  isPreset Boolean @default(false)
  tokens   Json
  preview  String?

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  presentations Presentation[]

  @@index([userId])
  @@index([isPreset])
  @@map("themes")
}

// ---- Section 4.2.5: Asset Model ----

model Asset {
  id             String    @id @default(cuid())
  userId         String
  presentationId String?
  type           AssetType
  url            String
  filename       String
  mimeType       String
  sizeBytes      Int
  metadata       Json?
  createdAt      DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  presentation Presentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([presentationId])
  @@map("assets")
}

// ---- NextAuth Models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
