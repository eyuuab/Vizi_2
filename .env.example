# ==========================================
# SlideForge AI — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values.

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/slideforge?schema=public"

# ---- NextAuth.js ----
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- OAuth Providers ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_ID=""
GITHUB_SECRET=""

# ---- Email (Resend) ----
RESEND_API_KEY=""

# ---- AI Providers ----
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""

# ---- File Storage (Cloudflare R2 / AWS S3) ----
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ---- Analytics ----
POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
