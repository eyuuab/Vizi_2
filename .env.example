# ==========================================
# SlideForge AI — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values.

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/slideforge?schema=public"

# ---- Clerk Auth ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# ---- AI Providers ----
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# ---- File Storage (Cloudflare R2 / AWS S3) ----
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ---- Analytics ----
POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
